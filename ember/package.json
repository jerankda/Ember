{
  "name": "ember",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev": "concurrently \"npm:dev:frontend\" \"npm:dev:server\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "markdown-it": "^14.2.0",
    "pinia": "^3.0.4",
    "shiki": "^4.1.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  }
}
